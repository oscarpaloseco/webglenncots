---
interface Props { name: "thyroid" | "gut" | "immune" | "metabolic"; size?: number; }
const { name, size = 26 } = Astro.props;
---
<span class="area-icon" style={`--s:${size}px`} aria-hidden="true">
  {name === "thyroid" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 4c-2 1.5-3 4-3 6.5C6 14 8 16 9.5 16.5 11 17 12 15 12 13c0 2 1 4 2.5 3.5C16 16 18 14 18 10.5 18 8 17 5.5 15 4" />
      <path d="M12 13V8" /><path d="M9.5 6.5h5" />
    </svg>
  )}
  {name === "gut" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 4v4a3 3 0 0 0 3 3 3 3 0 0 1 3 3 3 3 0 0 0 3 3h1" />
      <path d="M7 4h3" /><path d="M17 20v-3a3 3 0 0 0-3-3" /><path d="M10 7.5a2.5 2.5 0 0 1 0 5" />
    </svg>
  )}
  {name === "immune" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" />
      <path d="M9.2 12l1.8 1.8L15 10" />
    </svg>
  )}
  {name === "metabolic" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 14a8 8 0 0 1 16 0" /><path d="M12 14l4-4" /><circle cx="12" cy="14" r="1.4" fill="currentColor" stroke="none"/>
      <path d="M4 14h1M19 14h1M12 6v1" />
    </svg>
  )}
</span>

<style>
  .area-icon { display: inline-grid; place-items: center; width: var(--s); height: var(--s); color: var(--forest); }
  .area-icon svg { width: 100%; height: 100%; }
</style>
