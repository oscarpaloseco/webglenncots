---
import Base from "../layouts/Base.astro";
import Figure from "../components/Figure.astro";
import { servicios } from "../data/servicios";
import { site } from "../data/site";

const accent = (str: string) => {
  const t = str.trimEnd();
  const i = t.lastIndexOf(" ");
  return i === -1 ? t : `${t.slice(0, i)} <em>${t.slice(i + 1)}</em>`;
};
---

<Base
  title="Consulta de nutrición: tiroides, digestivo, autoinmunidad y metabolismo"
  description="Áreas de consulta de nutrición clínica y PNI: salud tiroidea, digestiva avanzada, enfermedades autoinmunes y salud metabólica. Cada área, una página trabajada."
>
  <section class="page-hero">
    <div class="container">
      <p class="kicker" data-reveal>Consulta de nutrición</p>
      <h1 data-reveal style="--reveal-delay:60ms">Nutrición clínica con nombre y apellidos: <em>el&nbsp;tuyo</em></h1>
      <p class="lead measure" data-reveal style="--reveal-delay:120ms">
        Trabajo cuatro grandes áreas que casi siempre están conectadas entre sí.
        Elijas por donde elijas empezar, el enfoque es el mismo: entender la causa
        raíz y construir contigo un plan sostenible. Entra en cada área para verlo
        en detalle.
      </p>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <div class="hub-grid">
        {servicios.map((s, i) => (
          <a href={`/consulta/${s.slug}`} class="hub-card" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <div class="hub-card__media">
              <Figure id={s.image.id} alt={s.image.alt} ratio="4 / 3" class="hub-card__img" sizes="(min-width:820px) 46vw, 100vw" />
              <span class="hub-card__num">{s.number}</span>
            </div>
            <div class="hub-card__body">
              <h2 class="hub-card__title" set:html={accent(s.title)} />
              <p class="hub-card__tag">{s.tagline}</p>
              <span class="hub-card__more">
                Ver el área en detalle
                <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <div class="hub-cta" data-reveal>
        <div>
          <h2>¿No sabes en qué <em>área encajas</em>?</h2>
          <p class="lead">Es normal. Muchas veces los síntomas se solapan. En una primera visita lo valoramos juntas y trazamos el camino.</p>
        </div>
        <a href={site.bookingUrl} class="btn">
          Pide cita
          <svg class="btn__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding-block: clamp(2.5rem, 1.8rem + 3vw, 4.5rem) var(--space-l); }
  .page-hero .lead { margin-top: var(--space-s); }
  .page-hero h1 { margin-top: var(--space-2xs); }

  .hub-grid { display: grid; gap: clamp(1.2rem, 3vw, 2.4rem); grid-template-columns: 1fr; }
  @media (min-width: 820px) { .hub-grid { grid-template-columns: 1fr 1fr; } }
  .hub-card { display: grid; gap: var(--space-s); }
  .hub-card__media { position: relative; overflow: hidden; border-radius: var(--r-lg); }
  .hub-card :global(.hub-card__img) img { transition: transform .7s cubic-bezier(.16,1,.3,1); }
  .hub-card:hover :global(.hub-card__img) img { transform: scale(1.04); }
  .hub-card__num { position: absolute; top: 0.9rem; left: 1rem; font-family: var(--display-italic); font-style: italic; font-size: 1.5rem; color: var(--on-forest); text-shadow: 0 1px 12px rgba(0,0,0,0.45); }
  .hub-card__title { font-size: var(--step-2); letter-spacing: -0.02em; }
  .hub-card__tag { color: var(--muted); margin-top: 0.35rem; font-size: 0.95rem; }
  .hub-card__more { display: inline-flex; align-items: center; gap: 0.45rem; font-weight: 600; font-size: 0.92rem; color: var(--forest); margin-top: var(--space-2xs); }
  .hub-card__more svg { transition: transform .35s cubic-bezier(.16,1,.3,1); }
  .hub-card:hover .hub-card__more { color: var(--terracotta); }
  .hub-card:hover .hub-card__more svg { transform: translateX(3px); }

  .hub-cta { border-radius: var(--r-lg); background: var(--bg-2); border: 1px solid var(--line); padding: clamp(2rem, 1.4rem + 3vw, 3.5rem); display: grid; gap: var(--space-m); align-items: center; }
  @media (min-width: 820px) { .hub-cta { grid-template-columns: 1.6fr auto; gap: var(--space-l); } }
  .hub-cta .lead { margin-top: 0.5rem; max-width: 46ch; }
</style>
