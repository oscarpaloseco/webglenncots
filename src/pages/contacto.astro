---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";

const faqs = [
  { q: "¿La consulta es online o presencial?", a: "Ambas. Puedes elegir la modalidad que mejor se adapte a ti; el seguimiento funciona igual de bien en las dos." },
  { q: "¿Necesito traer analíticas?", a: "Si tienes analíticas recientes, tráelas: nos ayudan mucho. Si no, te indico cuáles pedir para valorar tu caso a fondo." },
  { q: "¿Cómo es la primera visita?", a: "Es una sesión amplia donde revisamos tu historia, síntomas y objetivos. De ahí sale un plan personalizado y los primeros pasos." },
  { q: "¿En cuánto tiempo veré resultados?", a: "Depende de cada caso. La autoinmunidad y las patologías digestivas son procesos de meses; buscamos cambios sostenibles, no atajos." },
];
---

<Base
  title="Contacto y reserva de cita · Glenn Cots"
  description="Pide tu cita con Glenn Cots, dietista-nutricionista. Consulta online y presencial para tiroides, autoinmunidad y salud digestiva."
>
  <section class="page-hero">
    <div class="container contacto__grid">
      <div class="contacto__copy" data-reveal>
        <p class="kicker">Pide cita</p>
        <h1>Empecemos a trabajar en <em>tu salud</em></h1>
        <p class="lead">
          Cuéntame qué te ocurre y en qué te gustaría que te acompañe. Te responderé
          personalmente para agendar tu primera visita.
        </p>
        <ul class="contacto__direct" role="list">
          <li>
            <span class="contacto__ico" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 5 8-5"/></svg>
            </span>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
          <li>
            <span class="contacto__ico" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="16" height="16" rx="4.5"/><circle cx="12" cy="12" r="3.4"/><circle cx="17" cy="7" r="1" fill="currentColor" stroke="none"/></svg>
            </span>
            <a href={site.instagram} target="_blank" rel="noopener">@glenncots</a>
          </li>
          <li>
            <span class="contacto__ico" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s-7-5.2-7-10a7 7 0 0 1 14 0c0 4.8-7 10-7 10Z"/><circle cx="12" cy="11" r="2.5"/></svg>
            </span>
            <span>Consulta online y presencial</span>
          </li>
        </ul>
      </div>

      <div class="contacto__form-wrap" data-reveal style="--reveal-delay:100ms">
        <form class="contacto__form" data-contact>
          <div class="field">
            <label for="c-name">Nombre</label>
            <input id="c-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="c-email">Email</label>
            <input id="c-email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="c-topic">¿En qué te acompaño?</label>
            <select id="c-topic" name="topic">
              <option>Tiroides y patología endocrina</option>
              <option>Salud digestiva</option>
              <option>Enfermedad autoinmune</option>
              <option>Salud metabólica y peso</option>
              <option>Programa FUEGAS</option>
              <option>Otra consulta</option>
            </select>
          </div>
          <div class="field">
            <label for="c-msg">Cuéntame tu caso</label>
            <textarea id="c-msg" name="message" rows="4" required></textarea>
          </div>
          <button type="submit" class="btn contacto__submit">
            Enviar y pedir cita
            <svg class="btn__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <p class="contacto__ok" data-contact-ok hidden>
            ¡Gracias! He recibido tu mensaje y te responderé muy pronto.
          </p>
          <p class="contacto__legal">Al enviar aceptas que trate tus datos para responderte. Consulta la <a href="/privacidad">política de privacidad</a>.</p>
        </form>
      </div>
    </div>
  </section>

  <section class="section surface-cream2">
    <div class="container">
      <header class="faq__head" data-reveal>
        <p class="kicker">Preguntas frecuentes</p>
        <h2>Antes de tu primera visita</h2>
      </header>
      <div class="faq__list" data-reveal>
        {faqs.map((f) => (
          <details class="faq">
            <summary>
              {f.q}
              <span class="faq__icon" aria-hidden="true"></span>
            </summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding-block: clamp(2.5rem, 1.8rem + 3vw, 4.5rem) var(--space-xl); }
  .contacto__grid { display: grid; gap: var(--space-l); align-items: start; }
  @media (min-width: 880px) { .contacto__grid { grid-template-columns: 1fr 1fr; gap: var(--space-xl); } }
  .contacto__copy .lead { margin-top: var(--space-s); }
  .contacto__direct { display: grid; gap: var(--space-s); margin-top: var(--space-l); }
  .contacto__direct li { display: flex; align-items: center; gap: 0.8rem; }
  .contacto__ico { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 11px; background: var(--sage-pale); color: var(--forest); flex: none; }

  .contacto__form-wrap { background: var(--bg); border: 1px solid var(--line); border-radius: var(--r-lg); padding: clamp(1.4rem, 1rem + 2vw, 2.4rem); box-shadow: var(--shadow-m); }
  .contacto__form { display: grid; gap: var(--space-s); }
  .field { display: grid; gap: 0.35rem; }
  .field label { font-size: 0.88rem; font-weight: 600; color: var(--ink); }
  .field input, .field select, .field textarea {
    padding: 0.8em 1em; border-radius: var(--r); border: 1px solid var(--line); background: var(--bg-2); color: var(--ink);
    transition: border-color .2s, box-shadow .2s;
  }
  .field textarea { resize: vertical; }
  .field input:focus-visible, .field select:focus-visible, .field textarea:focus-visible {
    outline: none; border-color: var(--forest); box-shadow: 0 0 0 3px color-mix(in srgb, var(--forest) 15%, transparent);
  }
  .contacto__submit { justify-content: center; margin-top: 0.3rem; }
  .contacto__ok { background: var(--sage-pale); color: var(--forest); padding: 0.8em 1em; border-radius: var(--r); font-weight: 500; }
  .contacto__legal { font-size: 0.8rem; color: var(--muted); }
  .contacto__legal a { color: var(--forest); text-decoration: underline; }

  .faq__head { margin-bottom: var(--space-l); }
  .faq__list { display: grid; gap: 0.6rem; max-width: 52rem; }
  .faq { background: var(--bg); border: 1px solid var(--line); border-radius: var(--r); overflow: hidden; }
  .faq summary { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: var(--space-s) var(--space-m); cursor: pointer; font-weight: 600; color: var(--forest); font-size: 1.05rem; list-style: none; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq__icon { position: relative; flex: none; width: 16px; height: 16px; }
  .faq__icon::before, .faq__icon::after { content: ""; position: absolute; background: var(--terracotta); border-radius: 2px; transition: transform .3s; }
  .faq__icon::before { top: 7px; left: 0; width: 16px; height: 2px; }
  .faq__icon::after { top: 0; left: 7px; width: 2px; height: 16px; }
  .faq[open] .faq__icon::after { transform: scaleY(0); }
  .faq p { padding: 0 var(--space-m) var(--space-m); color: var(--ink-soft); max-width: 62ch; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact]");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const ok = form.querySelector<HTMLElement>("[data-contact-ok]");
    if (ok) ok.hidden = false;
    form.reset();
  });
</script>
