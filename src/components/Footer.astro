---
import { nav, site } from "../data/site";
const year = new Date().getFullYear();
---
<footer class="footer surface-forest">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <p class="footer__wordmark">Glenn Cots</p>
        <p class="footer__tag">
          No creo en las dietas milagro, sino en entender la causa raíz de cada
          síntoma y construir cambios de hábitos sostenibles.
        </p>
        <a href={site.bookingUrl} class="btn btn--on-dark">
          Pide cita
          <svg class="btn__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <nav class="footer__nav" aria-label="Pie de página">
        <p class="footer__heading">Navegación</p>
        <ul role="list">
          {nav.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </nav>

      <div class="footer__contact">
        <p class="footer__heading">Contacto</p>
        <ul role="list">
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><a href={site.instagram} target="_blank" rel="noopener">Instagram</a></li>
          <li class="footer__note">Consulta online y presencial</li>
        </ul>
      </div>
    </div>

    <hr class="footer__rule" />

    <div class="footer__bottom">
      <p>© {year} {site.name}. Dietista-Nutricionista col. nº —.</p>
      <p class="footer__legal">
        <a href="/aviso-legal">Aviso legal</a>
        <span aria-hidden="true">·</span>
        <a href="/privacidad">Privacidad</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--forest-deep); padding-block: var(--space-xl) var(--space-l); }
  .footer__top { display: grid; gap: var(--space-l); grid-template-columns: 1fr; }
  @media (min-width: 760px) { .footer__top { grid-template-columns: 1.6fr 1fr 1fr; gap: var(--space-xl); } }
  .footer__wordmark { font-family: var(--display-italic); font-style: italic; font-size: clamp(2.3rem, 1.6rem + 2.4vw, 3.4rem); color: var(--on-forest); line-height: 1; }
  .footer__tag { color: var(--on-forest-mut); max-width: 34ch; margin-block: var(--space-s) var(--space-m); font-size: 1.02rem; }
  .footer__heading { font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.12em; color: var(--sage); font-weight: 600; margin-bottom: var(--space-s); }
  .footer__nav ul, .footer__contact ul { display: grid; gap: 0.6rem; }
  .footer__nav a, .footer__contact a { color: var(--on-forest-mut); transition: color .2s; }
  .footer__nav a:hover, .footer__contact a:hover { color: var(--on-forest); }
  .footer__note { color: var(--sage); font-size: 0.92rem; }
  .footer__rule { border: 0; height: 1px; background: rgba(244,241,230,0.14); margin-block: var(--space-l); }
  .footer__bottom { display: flex; flex-wrap: wrap; gap: 0.6rem 1.5rem; justify-content: space-between; color: var(--on-forest-mut); font-size: 0.86rem; }
  .footer__legal { display: inline-flex; gap: 0.6rem; }
  .footer__legal a:hover { color: var(--on-forest); }
</style>
