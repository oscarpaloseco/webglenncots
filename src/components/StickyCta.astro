---
import { site } from "../data/site";
---
<a href={site.bookingUrl} class="sticky-cta" data-sticky-cta aria-label="Pide cita">
  <span class="sticky-cta__ring" aria-hidden="true">
    <svg viewBox="0 0 100 100">
      <defs>
        <path id="cta-circle" d="M50,50 m-37,0 a37,37 0 1,1 74,0 a37,37 0 1,1 -74,0" />
      </defs>
      <text><textPath href="#cta-circle" startOffset="0%">Pide cita · Reserva tu visita · Pide cita · Reserva tu visita · </textPath></text>
    </svg>
  </span>
  <span class="sticky-cta__arrow" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="20" height="20"><path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </span>
</a>

<style>
  .sticky-cta {
    position: fixed;
    right: clamp(1rem, 2vw, 2rem);
    bottom: clamp(1rem, 2vw, 2rem);
    z-index: var(--z-sticky-cta);
    width: 92px; height: 92px;
    display: grid; place-items: center;
    color: var(--on-forest);
    opacity: 0; transform: scale(0.6) translateY(10px);
    pointer-events: none;
    transition: opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1);
  }
  .sticky-cta[data-show] { opacity: 1; transform: none; pointer-events: auto; }
  .sticky-cta::before {
    content: ""; position: absolute; inset: 14px;
    background: var(--forest); border-radius: 50%;
    box-shadow: var(--shadow-l);
    transition: transform .4s cubic-bezier(.16,1,.3,1), background-color .3s;
  }
  .sticky-cta:hover::before { transform: scale(1.06); background: var(--forest-deep); }
  .sticky-cta__ring { position: absolute; inset: 0; color: var(--forest); }
  .sticky-cta__ring svg { width: 100%; height: 100%; animation: spin 22s linear infinite; }
  .sticky-cta__ring text { font-family: var(--sans); font-size: 8.6px; font-weight: 600; letter-spacing: 0.02em; fill: var(--forest); text-transform: uppercase; }
  .sticky-cta__arrow { position: relative; z-index: 1; transition: transform .4s cubic-bezier(.16,1,.3,1); }
  .sticky-cta:hover .sticky-cta__arrow { transform: rotate(45deg); }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .sticky-cta__ring svg { animation: none; }
    .sticky-cta { transition: opacity .3s; transform: none; }
    .sticky-cta:not([data-show]) { transform: none; }
  }
  @media (max-width: 600px) { .sticky-cta { width: 74px; height: 74px; } .sticky-cta__ring text { font-size: 9.4px; } }
</style>

<script>
  const cta = document.querySelector<HTMLElement>("[data-sticky-cta]");
  const toggle = () => {
    if (!cta) return;
    if (window.scrollY > window.innerHeight * 0.75) cta.setAttribute("data-show", "");
    else cta.removeAttribute("data-show");
  };
  toggle();
  window.addEventListener("scroll", toggle, { passive: true });
</script>
