---
import Base from "../layouts/Base.astro";
import Figure from "../components/Figure.astro";
import AreaIcon from "../components/AreaIcon.astro";
import { servicios } from "../data/servicios";
import { site } from "../data/site";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const method = [
  { n: "01", t: "Causa raíz", d: "Analizamos tu historia, tus analíticas y tus síntomas para entender qué los origina, no solo para taparlos." },
  { n: "02", t: "Plan personalizado", d: "Un abordaje a tu medida: alimentación, cronobiología, suplementación justa y estilo de vida. Nada de plantillas." },
  { n: "03", t: "Acompañamiento", d: "Revisiones y ajustes constantes. Estoy contigo en el proceso, también cuando aparecen las dudas y las recaídas." },
  { n: "04", t: "Hábitos sostenibles", d: "El objetivo no es una dieta más, sino cambios que se sostienen en el tiempo y te devuelven autonomía." },
];

// Ticker: palabras alternadas con imágenes (estilo bewellbykelly)
const ticker = [
  { w: "Hipotiroidismo", img: "photo-1505576399279-565b52d4ac71" },
  { w: "Hashimoto", img: "photo-1519708227418-c8fd9a32b7a2" },
  { w: "SIBO", img: "photo-1490645935967-10de6ba17061" },
  { w: "Permeabilidad intestinal", img: "photo-1519996529931-28324d5a630e" },
  { w: "Psoriasis", img: "photo-1466637574441-749b8f19452f" },
  { w: "Resistencia a la insulina", img: "photo-1512621776951-a57141f2eefd" },
  { w: "Enfermedad celíaca", img: "photo-1607532941433-304659e8198a" },
  { w: "Colitis y Crohn", img: "photo-1543362906-acfc16c67564" },
];
const tickerImg = (id: string) =>
  `https://images.unsplash.com/${id}?auto=format&fit=crop&q=80&w=160&h=160`;
---

<Base>
  <!-- ===== HERO (full-bleed) ===== -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?auto=format&fit=crop&q=80&w=2000"
        srcset="https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?auto=format&fit=crop&q=80&w=1200 1200w, https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?auto=format&fit=crop&q=80&w=2000 2000w"
        sizes="100vw"
        alt=""
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero__scrim"></div>
    </div>

    <div class="container hero__inner">
      <p class="hero__kicker" data-reveal>Dietista-Nutricionista · Tiroides y autoinmunidad</p>
      <h1 class="hero__title" data-reveal style="--reveal-delay:100ms">
        <span class="hero__line-sans">Tu salud, entendida</span>
        <span class="hero__line-serif">desde&nbsp;dentro</span>
      </h1>
      <p class="hero__lead" data-reveal style="--reveal-delay:200ms">
        Acompaño a personas con patología tiroidea, enfermedades autoinmunes y
        problemas digestivos a recuperar su salud tratando la causa raíz, con
        nutrición clínica y PNI.
      </p>
      <div class="hero__actions" data-reveal style="--reveal-delay:300ms">
        <a href={site.bookingUrl} class="btn btn--on-dark">
          Pide cita
          <svg class="btn__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/consulta" class="btn btn--on-dark btn--ghost">Ver áreas de consulta</a>
      </div>
      <ul class="hero__trust" role="list" data-reveal style="--reveal-delay:400ms">
        <li><strong>Nutrición Humana y Dietética</strong> · UVIC</li>
        <li><strong>Formación en PNI</strong> · SoyPro</li>
        <li><strong>Paciente de Hashimoto</strong></li>
      </ul>
    </div>

    <span class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-line"></span>
    </span>
  </section>

  <!-- ===== TICKER (texto + imágenes) ===== -->
  <section class="ticker" aria-label="Áreas que trabajo">
    <div class="ticker__track">
      {Array.from({ length: 2 }).map(() => (
        <div class="ticker__group" aria-hidden="true">
          {ticker.map((t) => (
            <>
              <span class="ticker__word">{t.w}</span>
              <span class="ticker__img"><img src={tickerImg(t.img)} alt="" loading="lazy" decoding="async" width="120" height="120" /></span>
            </>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ===== PRESENTACIÓN (image-with-text, estilo bewell) ===== -->
  <section class="section about">
    <div class="container about__grid">
      <div class="about__media" data-reveal>
        <Figure id="photo-1556911220-bff31c812dba" alt="Manos preparando alimentos frescos sobre una encimera" ratio="5 / 6" class="about__img" sizes="(min-width:820px) 44vw, 100vw" />
      </div>
      <div class="about__copy" data-reveal style="--reveal-delay:100ms">
        <p class="about__statement">
          <span class="about__label">Quién soy —</span>
          Soy Glenn Cots, dietista-nutricionista especializada en tiroides y
          autoinmunidad, y también <em>paciente de Hashimoto</em>. No creo en
          las dietas milagro, sino en entender la causa raíz de cada síntoma y
          construir cambios de hábitos sostenibles.
        </p>
        <a href="/sobre-mi" class="link-underline about__link">
          Conoce mi historia
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== ÁREAS (tiles con imagen, estilo bewell) ===== -->
  <section class="section areas" id="areas">
    <div class="container">
      <header class="areas__head" data-reveal>
        <p class="kicker">Consulta</p>
        <h2>En qué te <em>acompaño</em></h2>
      </header>

      <div class="areas__grid">
        {servicios.map((s, i) => (
          <a href={`/consulta/${s.slug}`} class="area-tile" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <div class="area-tile__media">
              <Figure id={s.image.id} alt={s.image.alt} ratio="4 / 5" class="area-tile__img" sizes="(min-width:900px) 23vw, 45vw" />
              <span class="area-tile__num">{s.number}</span>
            </div>
            <div class="area-tile__foot">
              <h3 class="area-tile__title">{s.title}</h3>
              <svg class="area-tile__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MÉTODO ===== -->
  <section class="section method">
    <div class="container">
      <header class="method__head" data-reveal>
        <p class="kicker">Cómo trabajo</p>
        <h2>Un método, <em>no una dieta</em></h2>
        <p class="lead measure">
          Nada de restricciones imposibles ni soluciones exprés. Un proceso ordenado
          que te devuelve el control sobre tu salud.
        </p>
      </header>
      <ol class="method__list" role="list">
        {method.map((s, i) => (
          <li class="method__step" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="method__num">{s.n}</span>
            <h3 class="method__title">{s.t}</h3>
            <p class="method__desc">{s.d}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== SERVICIOS ===== -->
  <section class="section surface-cream2 services">
    <div class="container">
      <header class="services__head" data-reveal>
        <p class="kicker">Más allá de la consulta</p>
        <h2>Otros <em>servicios</em></h2>
      </header>
      <div class="services__grid">
        <a href="/programa-fuegas" class="service-card service-card--feature" data-reveal>
          <div class="service-card__body">
            <span class="badge">Acompañamiento en grupo</span>
            <h3>Programa FUEGAS</h3>
            <p>Un programa para reconectar con tu energía y tus hábitos, en comunidad y con acompañamiento cercano durante todo el proceso.</p>
            <span class="link-underline">Descubre el programa
              <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <Figure id="photo-1540420773420-3366772f4999" alt="Persona cocinando alimentos frescos en una cocina luminosa" ratio="16 / 10" class="service-card__img" sizes="(min-width:900px) 42vw, 100vw" />
        </a>

        <a href="/ebooks" class="service-card" data-reveal style="--reveal-delay:90ms">
          <span class="service-card__icon"><AreaIcon name="immune" size={22} /></span>
          <h3>Ebooks y recursos</h3>
          <p>Guías descargables sobre tiroides, salud digestiva y alimentación antiinflamatoria.</p>
          <span class="service-card__more">Ver recursos →</span>
        </a>

        <a href={site.productsUrl} class="service-card" data-reveal style="--reveal-delay:160ms">
          <span class="service-card__icon"><AreaIcon name="metabolic" size={22} /></span>
          <h3>Productos recomendados</h3>
          <p>Mi selección de productos y suplementos de confianza para acompañar tu proceso.</p>
          <span class="service-card__more">Ver la selección →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== BLOG ===== -->
  {posts.length > 0 && (
    <section class="section blog-teaser">
      <div class="container">
        <header class="blog-teaser__head" data-reveal>
          <div>
            <p class="kicker">Desde el blog</p>
            <h2>Recursos y <em>divulgación</em></h2>
          </div>
          <a href="/blog" class="btn btn--ghost">Ver todo el blog</a>
        </header>
        <div class="blog-teaser__grid">
          {posts.map((post, i) => (
            <a href={`/blog/${post.id}`} class="post-card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
              <Figure id={post.data.image} alt={post.data.imageAlt} ratio="16 / 10" class="post-card__img" sizes="(min-width:900px) 30vw, 100vw" />
              <div class="post-card__body">
                <span class="post-card__cat">{post.data.category}</span>
                <h3 class="post-card__title">{post.data.title}</h3>
                <p class="post-card__excerpt">{post.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== CTA FINAL ===== -->
  <section class="cta-final">
    <div class="container">
      <div class="cta-final__panel" data-reveal>
        <p class="kicker">Empecemos</p>
        <h2>Da el primer paso hacia <em>tu salud</em></h2>
        <p class="lead">
          Reserva tu primera visita y trabajemos juntas en entender qué le pasa a tu
          cuerpo y cómo ayudarle. Consulta online y presencial.
        </p>
        <div class="cta-final__actions">
          <a href={site.bookingUrl} class="btn">
            Pide cita
            <svg class="btn__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href={`mailto:${site.email}`} class="btn btn--ghost">Escríbeme un email</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* HERO — full-bleed image + texto centrado (estilo referencia) */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(-1 * var(--header-h));
    display: grid;
    align-items: center;
    justify-items: center;
    text-align: center;
    padding-top: calc(var(--header-h) + var(--space-l));
    padding-bottom: var(--space-2xl);
    overflow: clip;
    isolation: isolate;
  }
  .hero__bg { position: absolute; inset: 0; z-index: -1; }
  .hero__bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(26,23,19,0.60) 0%, rgba(26,23,19,0.46) 45%, rgba(20,18,15,0.78) 100%),
      radial-gradient(115% 75% at 50% 42%, rgba(20,18,15,0.15) 20%, rgba(20,18,15,0.55) 100%);
  }

  .hero__inner {
    display: grid;
    justify-items: center;
    gap: var(--space-s);
    max-width: 60rem;
  }
  .hero__kicker {
    font-family: var(--sans-alt);
    font-size: 0.8rem; font-weight: 500;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--sage);
  }
  .hero__title {
    color: var(--on-forest);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin-block: 0.2rem 0.3rem;
    text-wrap: balance;
    text-shadow: 0 1px 30px rgba(20,18,15,0.35);
  }
  .hero__line-sans,
  .hero__line-serif { display: block; }
  .hero__line-sans {
    font-family: var(--sans-alt);
    font-weight: 500;
    font-size: clamp(2.4rem, 1.4rem + 4.6vw, 5rem);
  }
  .hero__line-serif {
    font-family: var(--display-italic);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.9rem, 1.5rem + 6.4vw, 6.4rem);
    letter-spacing: -0.01em;
    color: inherit;
  }
  .hero__lead {
    font-family: var(--sans-alt);
    font-size: clamp(1.02rem, 0.96rem + 0.4vw, 1.2rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--on-forest) 88%, transparent);
    max-width: 46ch;
    margin-top: var(--space-2xs);
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-xs); justify-content: center; margin-top: var(--space-m); }
  .hero__trust {
    display: flex; flex-wrap: wrap; gap: 0.4rem 1.3rem; justify-content: center;
    margin-top: var(--space-l); font-family: var(--sans-alt);
    font-size: 0.85rem; color: color-mix(in srgb, var(--on-forest) 72%, transparent);
  }
  .hero__trust li { position: relative; padding-left: 1.05rem; }
  .hero__trust li::before { content: ""; position: absolute; left: 0; top: 0.5em; width: 5px; height: 5px; border-radius: 50%; background: var(--sage); }
  .hero__trust strong { color: var(--on-forest); font-weight: 600; }

  .hero__scroll {
    position: absolute; bottom: 1.4rem; left: 50%; transform: translateX(-50%);
    width: 1px; height: 44px; overflow: hidden;
  }
  .hero__scroll-line { position: absolute; inset: 0; background: color-mix(in srgb, var(--on-forest) 55%, transparent); animation: heroScroll 2.4s cubic-bezier(.6,0,.2,1) infinite; }
  @keyframes heroScroll { 0% { transform: translateY(-100%); } 60%,100% { transform: translateY(100%); } }
  @media (prefers-reduced-motion: reduce) { .hero__scroll-line { animation: none; } }

  /* TICKER — texto + imágenes (estilo bewellbykelly) */
  .ticker { overflow: hidden; padding-block: clamp(0.9rem, 0.6rem + 1vw, 1.6rem); background: var(--bg-2); border-block: 1px solid var(--line); }
  .ticker__track { display: flex; width: max-content; animation: ticker 55s linear infinite; }
  .ticker__group { display: inline-flex; align-items: center; }
  .ticker__word {
    font-family: var(--display-italic); font-style: italic;
    font-size: clamp(1.4rem, 1rem + 1.7vw, 2.5rem);
    color: var(--forest); white-space: nowrap;
    padding-inline: clamp(0.7rem, 1.4vw, 1.5rem);
  }
  .ticker__img {
    flex: none; width: clamp(46px, 5.2vw, 70px); aspect-ratio: 1;
    margin-inline: clamp(0.35rem, 0.9vw, 0.8rem);
    border-radius: var(--r); overflow: hidden;
  }
  .ticker__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ticker__track:hover { animation-play-state: paused; }
  @keyframes ticker { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .ticker__track { animation: none; } }

  /* ABOUT — image-with-text (una declaración editorial, estilo bewell) */
  .about__grid { display: grid; gap: var(--space-l); align-items: center; }
  @media (min-width: 820px) { .about__grid { grid-template-columns: 0.82fr 1.18fr; gap: clamp(2.5rem, 5vw, 5rem); } }
  .about__media :global(.about__img) { border-radius: var(--r-lg); }
  .about__statement {
    font-family: var(--sans);
    font-weight: 500;
    font-size: clamp(1.5rem, 1.1rem + 1.7vw, 2.4rem);
    line-height: 1.32;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-wrap: pretty;
  }
  .about__statement em {
    font-family: var(--display-italic); font-style: italic; font-weight: 400;
    color: inherit; font-size: 1.05em;
  }
  .about__label {
    font-family: var(--sans); font-weight: 600;
    font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--terracotta); white-space: nowrap;
    margin-right: 0.35rem; vertical-align: 0.18em;
  }
  .about__link { margin-top: var(--space-m); }

  /* AREAS — tiles con imagen (blanco, editorial) */
  .areas__head { margin-bottom: var(--space-l); display: grid; gap: 0.5rem; }
  .areas__grid { display: grid; gap: clamp(1rem, 2vw, 1.6rem); grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 900px) { .areas__grid { grid-template-columns: repeat(4, 1fr); } }
  .area-tile { display: block; }
  .area-tile__media { position: relative; overflow: hidden; border-radius: var(--r-lg); }
  .area-tile :global(.area-tile__img) img { transition: transform .7s cubic-bezier(.16,1,.3,1); }
  .area-tile:hover :global(.area-tile__img) img { transform: scale(1.05); }
  .area-tile__num {
    position: absolute; top: 0.75rem; left: 0.9rem;
    font-family: var(--display-italic); font-style: italic; font-size: 1.35rem;
    color: var(--on-forest); text-shadow: 0 1px 12px rgba(0,0,0,0.45);
  }
  .area-tile__foot { display: flex; align-items: center; justify-content: space-between; gap: 0.7rem; margin-top: var(--space-s); }
  .area-tile__title { font-size: var(--step-1); line-height: 1.15; letter-spacing: -0.02em; }
  .area-tile__arrow { color: var(--muted); flex: none; transition: transform .35s cubic-bezier(.16,1,.3,1), color .3s; }
  .area-tile:hover .area-tile__arrow { transform: translateX(3px); color: var(--terracotta); }

  /* MÉTODO */
  .method__head { max-width: 60ch; margin-bottom: var(--space-l); display: grid; gap: 0.6rem; }
  .method__list { display: grid; gap: var(--space-m); grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); }
  .method__step { position: relative; padding-top: var(--space-m); border-top: 2px solid var(--forest); }
  .method__num { font-family: var(--serif); font-style: italic; font-size: 1.5rem; color: var(--terracotta); }
  .method__title { font-size: var(--step-1); margin-top: 0.3rem; }
  .method__desc { color: var(--muted); font-size: 0.96rem; margin-top: 0.4rem; }

  /* SERVICIOS */
  .services__head { margin-bottom: var(--space-l); }
  .services__grid { display: grid; gap: var(--space-s); grid-template-columns: 1fr; }
  @media (min-width: 760px) { .services__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1020px) { .services__grid { grid-template-columns: 1.4fr 1fr 1fr; } }
  .service-card {
    display: flex; flex-direction: column; gap: 0.6rem;
    background: var(--bg); border: 1px solid var(--line); border-radius: var(--r-lg);
    padding: var(--space-m); transition: transform .4s cubic-bezier(.16,1,.3,1), box-shadow .4s;
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-m); }
  .service-card__icon { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 12px; background: var(--sage-pale); }
  .service-card h3 { font-size: var(--step-1); }
  .service-card p { color: var(--muted); font-size: 0.96rem; flex: 1; }
  .service-card__more { font-weight: 600; color: var(--forest); font-size: 0.92rem; }
  .service-card--feature { grid-row: span 2; padding: 0; overflow: hidden; }
  @media (min-width: 1020px) { .service-card--feature { grid-column: 1; grid-row: 1 / span 2; } }
  .service-card--feature .service-card__body { padding: var(--space-m); display: flex; flex-direction: column; gap: 0.7rem; }
  .service-card--feature :global(.service-card__img) { border-radius: 0; margin-top: auto; }

  /* BLOG */
  .blog-teaser__head { display: flex; flex-wrap: wrap; gap: var(--space-s); justify-content: space-between; align-items: end; margin-bottom: var(--space-l); }
  .blog-teaser__grid { display: grid; gap: var(--space-m); grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); }
  .post-card { display: flex; flex-direction: column; gap: 0.85rem; }
  .post-card :global(.post-card__img) { transition: transform .5s cubic-bezier(.16,1,.3,1); }
  .post-card:hover :global(.post-card__img) img { transform: scale(1.04); }
  .post-card__body { display: flex; flex-direction: column; gap: 0.4rem; }
  .post-card__cat { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--terracotta); }
  .post-card__title { font-size: var(--step-1); }
  .post-card__excerpt { color: var(--muted); font-size: 0.95rem; }

  /* CTA — panel claro */
  .cta-final { padding-block: var(--space-xl); }
  .cta-final__panel {
    border-radius: var(--r-lg);
    background: var(--bg-2);
