---
import Base from "../../layouts/Base.astro";
import Figure from "../../components/Figure.astro";
import { getCollection, render } from "astro:content";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" });

const related = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((p) => p.id !== post.id)
  .slice(0, 2);
---

<Base title={`${post.data.title} · Glenn Cots`} description={post.data.excerpt}>
  <article class="post">
    <header class="post__header">
      <div class="container post__header-inner">
        <a href="/blog" class="post__back">← Volver al blog</a>
        <div class="post__meta">
          <span class="pill-cat">{post.data.category}</span>
          <span>{fmt(post.data.date)}</span>
          <span aria-hidden="true">·</span>
          <span>{post.data.readingTime} de lectura</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="lead post__excerpt">{post.data.excerpt}</p>
      </div>
    </header>

    <div class="container">
      <Figure id={post.data.image} alt={post.data.imageAlt} ratio="16 / 9" class="post__cover" eager sizes="(min-width:1000px) 900px, 100vw" />
    </div>

    <div class="container post__layout">
      <div class="post__body">
        <Content />
      </div>
      <aside class="post__aside">
        <div class="post__cta">
          <p class="post__cta-kicker">¿Te ha resonado?</p>
          <p class="post__cta-title">Trabajemos tu caso en consulta</p>
          <a href={site.bookingUrl} class="btn">Pide cita</a>
        </div>
      </aside>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section surface-cream2">
      <div class="container">
        <h2 class="related__title">Sigue <em>leyendo</em></h2>
        <div class="related__grid">
          {related.map((p) => (
            <a href={`/blog/${p.id}`} class="post-card">
              <Figure id={p.data.image} alt={p.data.imageAlt} ratio="16 / 10" class="post-card__img" sizes="(min-width:900px) 45vw, 100vw" />
              <div class="post-card__body">
                <span class="pill-cat pill-cat--sm">{p.data.category}</span>
                <h3 class="post-card__title">{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .post__header { padding-block: clamp(2rem, 1.4rem + 3vw, 4rem) var(--space-l); }
  .post__header-inner { max-width: 52rem; display: grid; gap: var(--space-s); }
  .post__back { color: var(--muted); font-weight: 500; font-size: 0.9rem; width: max-content; }
  .post__back:hover { color: var(--forest); }
  .post__meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem; font-size: 0.85rem; color: var(--muted); }
  .post__header h1 { font-size: var(--step-4); }
  .post__excerpt { max-width: 54ch; }
  .pill-cat { font-size: 0.76rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--forest); background: var(--sage-pale); padding: 0.35em 0.75em; border-radius: var(--r-pill); }
  .pill-cat--sm { font-size: 0.72rem; }

  .post :global(.post__cover) { margin-block: var(--space-m) var(--space-xl); max-width: 60rem; margin-inline: auto; }

  .post__layout { display: grid; gap: var(--space-xl); align-items: start; }
  @media (min-width: 940px) { .post__layout { grid-template-columns: minmax(0, 1fr) 18rem; } }
  .post__body { max-width: 40rem; }
  .post__body :global(p) { margin-block: var(--space-s); color: var(--ink-soft); line-height: 1.75; }
  .post__body :global(h2) { font-size: var(--step-2); margin-top: var(--space-l); margin-bottom: var(--space-2xs); }
  .post__body :global(h3) { font-size: var(--step-1); margin-top: var(--space-m); }
  .post__body :global(ul), .post__body :global(ol) { margin-block: var(--space-s); padding-left: 1.3rem; display: grid; gap: 0.5rem; color: var(--ink-soft); }
  .post__body :global(li)::marker { color: var(--terracotta); }
  .post__body :global(strong) { color: var(--ink); }
  .post__body :global(blockquote) { margin-block: var(--space-m); padding: var(--space-s) var(--space-m); border-radius: var(--r); background: var(--sage-pale); font-family: var(--serif); font-style: italic; font-size: var(--step-1); color: var(--forest); }
  .post__body :global(blockquote p) { color: inherit; margin: 0; }

  .post__aside { position: sticky; top: 6rem; }
  .post__cta { background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--r-lg); padding: var(--space-m); display: grid; gap: 0.6rem; }
  .post__cta-kicker { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--terracotta); }
  .post__cta-title { font-family: var(--serif); font-size: 1.4rem; color: var(--forest); line-height: 1.15; }
  .post__cta .btn { margin-top: 0.3rem; justify-content: center; }

  .related__title { font-size: var(--step-2); margin-bottom: var(--space-m); }
  .related__grid { display: grid; gap: var(--space-m); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .post-card { display: flex; flex-direction: column; gap: 0.7rem; }
  .post-card :global(.post-card__img) { transition: transform .5s cubic-bezier(.16,1,.3,1); }
  .post-card:hover :global(.post-card__img) img { transform: scale(1.04); }
  .post-card__body { display: grid; gap: 0.4rem; }
  .post-card__title { font-size: var(--step-1); }
</style>
