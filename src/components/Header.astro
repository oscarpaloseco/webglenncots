---
import { nav, site } from "../data/site";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href.split("#")[0]);
// La home tiene hero oscuro a pantalla completa: el header va superpuesto y claro
// hasta que se hace scroll.
const overlay = path === "/";
---

<header class="site-header" data-header data-overlay={overlay ? "" : undefined}>
  <div class="container header__inner">
    <a href="/" class="brand" aria-label={`${site.name} — inicio`}>
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 21c0-6 0-9 0-12" />
          <path d="M12 11c-1.2-3.2-4-4.6-7-4.6.2 3.8 2.8 6 7 6.4Z" fill="currentColor" fill-opacity="0.12" />
          <path d="M12 9.5c1-3 3.6-4.4 6.4-4.4-.2 3.4-2.6 5.4-6.4 5.6Z" fill="currentColor" fill-opacity="0.2" />
        </svg>
      </span>
      <span class="brand__text">
        <span class="brand__name">{site.name}</span>
        <span class="brand__role">{site.role}</span>
      </span>
    </a>

    <nav class="nav" aria-label="Principal">
      <ul role="list" class="nav__list">
        {nav.map((item) => (
          <li class={`nav__item${item.children ? " has-children" : ""}`}>
            <a href={item.href} class="nav__link" aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
              {item.children && (
                <svg class="nav__chev" viewBox="0 0 12 12" width="11" height="11" aria-hidden="true"><path d="M2.5 4.5 6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              )}
            </a>
            {item.children && (
              <div class="dropdown">
                <ul role="list" class="dropdown__list">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href} class="dropdown__link">
                        <span class="dropdown__label">{child.label}</span>
                        {child.desc && <span class="dropdown__desc">{child.desc}</span>}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <a href={site.bookingUrl} class="btn header__cta">
      Pide cita
      <svg class="btn__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>

    <button class="burger" data-burger aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-drawer">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Drawer móvil -->
  <div class="drawer" id="mobile-drawer" data-drawer hidden>
    <ul role="list" class="drawer__list">
      {nav.map((item) => (
        <li>
          <a href={item.href} class="drawer__link">{item.label}</a>
          {item.children && (
            <ul role="list" class="drawer__sub">
              {item.children.map((child) => (
                <li><a href={child.href}>{child.label}</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <a href={site.bookingUrl} class="btn drawer__cta">Pide cita</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color .3s, background-color .3s, box-shadow .3s;
  }
  .site-header[data-scrolled] {
    border-bottom-color: var(--line);
    box-shadow: 0 4px 20px rgba(46, 41, 30, 0.05);
  }
  .header__inner {
    display: flex; align-items: center; gap: var(--space-m);
    min-height: var(--header-h);
  }

  /* Overlay claro sobre el hero oscuro (home, sin scroll) */
  .site-header[data-overlay]:not([data-scrolled]) {
    background: linear-gradient(180deg, rgba(16,26,14,0.28), transparent);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }
  .site-header[data-overlay]:not([data-scrolled]) .brand__mark,
  .site-header[data-overlay]:not([data-scrolled]) .brand__name { color: var(--on-forest); }
  .site-header[data-overlay]:not([data-scrolled]) .brand__role { color: color-mix(in srgb, var(--on-forest) 70%, transparent); }
  .site-header[data-overlay]:not([data-scrolled]) .nav__link { color: color-mix(in srgb, var(--on-forest) 82%, transparent); }
  .site-header[data-overlay]:not([data-scrolled]) .nav__link:hover,
  .site-header[data-overlay]:not([data-scrolled]) .nav__item:hover .nav__link { color: var(--on-forest); background: rgba(244,241,230,0.12); }
  .site-header[data-overlay]:not([data-scrolled]) .nav__link[aria-current="page"] { color: var(--on-forest); }
  .site-header[data-overlay]:not([data-scrolled]) .header__cta { background: var(--on-forest); color: var(--forest); }
  .site-header[data-overlay]:not([data-scrolled]) .burger span { background: var(--on-forest); }

  .brand { display: inline-flex; align-items: center; gap: 0.65rem; margin-right: auto; }
  .brand__mark { color: var(--forest); display: grid; place-items: center; }
  .brand__text { display: flex; flex-direction: column; line-height: 1.05; }
  .brand__name { font-family: var(--serif); font-size: 1.32rem; color: var(--forest); letter-spacing: -0.01em; }
  .brand__role { font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); font-weight: 600; }

  .nav { display: none; }
  @media (min-width: 960px) { .nav { display: block; } }
  .nav__list { display: flex; align-items: center; gap: 0.4rem; }
  .nav__item { position: relative; }
  .nav__link {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.6rem 0.8rem; border-radius: var(--r-sm);
    font-weight: 500; font-size: 0.98rem; color: var(--ink-soft);
    transition: color .2s, background-color .2s;
  }
  .nav__link:hover, .nav__item:hover .nav__link { color: var(--forest); background: color-mix(in srgb, var(--sage-pale) 70%, transparent); }
  .nav__link[aria-current="page"] { color: var(--forest); }
  .nav__chev { transition: transform .3s; }
  .nav__item:hover .nav__chev { transform: rotate(180deg); }

  .dropdown {
    position: absolute; top: calc(100% + 0.4rem); left: 0;
    min-width: 20rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--r);
    box-shadow: var(--shadow-l);
    padding: 0.5rem;
    opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: opacity .28s cubic-bezier(.16,1,.3,1), transform .28s cubic-bezier(.16,1,.3,1), visibility .28s;
  }
  .nav__item.has-children:hover .dropdown,
  .nav__item.has-children:focus-within .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown__list { display: grid; gap: 2px; }
  .dropdown__link { display: block; padding: 0.7rem 0.85rem; border-radius: var(--r-sm); transition: background-color .2s; }
  .dropdown__link:hover { background: var(--sage-pale); }
  .dropdown__label { display: block; font-weight: 600; color: var(--forest); font-size: 0.97rem; }
  .dropdown__desc { display: block; font-size: 0.82rem; color: var(--muted); margin-top: 1px; }

  .header__cta { display: none; padding: 0.7em 1.2em; font-size: 0.95rem; }
  @media (min-width: 960px) { .header__cta { display: inline-flex; } }

  /* Burger */
  .burger { display: inline-grid; gap: 5px; padding: 0.5rem; margin-left: auto; }
  @media (min-width: 960px) { .burger { display: none; } }
  .burger span { width: 24px; height: 2px; background: var(--forest); border-radius: 2px; transition: transform .3s, opacity .3s; }
  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Drawer */
  .drawer {
    display: none;
    border-top: 1px solid var(--line);
    background: var(--bg);
    padding: var(--space-m) var(--space-m) var(--space-l);
  }
  .drawer[data-open] { display: block; animation: drawer .3s cubic-bezier(.16,1,.3,1); }
  @keyframes drawer { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: none; } }
  .drawer__list { display: grid; gap: 0.2rem; }
  .drawer__link { display: block; font-family: var(--serif); font-size: 1.5rem; color: var(--forest); padding: 0.5rem 0; }
  .drawer__sub { display: grid; gap: 0.1rem; padding: 0 0 0.6rem 0.2rem; }
  .drawer__sub a { display: block; padding: 0.35rem 0; color: var(--muted); font-size: 0.98rem; }
  .drawer__cta { margin-top: var(--space-s); width: 100%; justify-content: center; }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-header]");
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 12) header.setAttribute("data-scrolled", "");
    else header.removeAttribute("data-scrolled");
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
  const drawer = document.querySelector<HTMLElement>("[data-drawer]");
  burger?.addEventListener("click", () => {
    const open = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!open));
    burger.setAttribute("aria-label", open ? "Abrir menú" : "Cerrar menú");
    if (drawer) {
      if (open) { drawer.removeAttribute("data-open"); drawer.hidden = true; }
      else { drawer.hidden = false; drawer.setAttribute("data-open", ""); }
    }
  });
</script>
