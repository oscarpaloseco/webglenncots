---
import Base from "../layouts/Base.astro";
import Figure from "../components/Figure.astro";
import AreaIcon from "../components/AreaIcon.astro";
import { areas } from "../data/areas";
import { site } from "../data/site";
---

<Base
  title="Consulta de nutrición · Glenn Cots"
  description="Áreas de consulta: salud tiroidea, digestiva avanzada, enfermedades autoinmunes y salud metabólica. Nutrición clínica y PNI para tratar la causa raíz."
>
  <!-- Cabecera -->
  <section class="page-hero">
    <div class="container">
      <p class="kicker" data-reveal>Consulta de nutrición</p>
      <h1 data-reveal style="--reveal-delay:60ms">Nutrición clínica con nombre y apellidos: <em>el&nbsp;tuyo</em></h1>
      <p class="lead measure" data-reveal style="--reveal-delay:120ms">
        Trabajo cuatro grandes áreas que casi siempre están conectadas entre sí.
        Elijas por donde elijas empezar, el enfoque es el mismo: entender la causa
        raíz y construir contigo un plan sostenible.
      </p>
    </div>
  </section>

  <!-- Sub-nav anclada -->
  <nav class="subnav" aria-label="Áreas de consulta">
    <div class="container subnav__inner">
      {areas.map((a) => (
        <a href={`#${a.id}`} class="subnav__link">
          <span class="subnav__num">{a.number}</span>{a.short}
        </a>
      ))}
    </div>
  </nav>

  <!-- Áreas -->
  {areas.map((area, i) => (
    <section class={`area-detail ${i % 2 === 1 ? "surface-sage" : ""}`} id={area.id}>
      <div class="container area-detail__grid">
        <div class={`area-detail__media ${i % 2 === 1 ? "is-right" : ""}`} data-reveal>
          <Figure id={area.image.id} alt={area.image.alt} ratio="4 / 3" sizes="(min-width:900px) 44vw, 100vw" />
          <span class="area-detail__badge"><AreaIcon name={area.icon} size={26} /></span>
        </div>
        <div class="area-detail__copy" data-reveal style="--reveal-delay:100ms">
          <div class="area-detail__head">
            <span class="area-detail__num eyebrow-num">{area.number}</span>
            <h2>{area.title}</h2>
          </div>
          <p class="lead">{area.intro}</p>
          <ul class="area-detail__list" role="list">
            {area.items.map((item) => (
              <li>
                <span class="area-detail__check" aria-hidden="true">
                  <svg viewBox="0 0 16 16" width="13" height="13"><path d="M3 8.5 6.5 12 13 4.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <div>
                  <p class="area-detail__name">{item.name}</p>
                  <p class="area-detail__desc">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="consulta-cta surface-forest" data-reveal>
        <div>
          <h2>¿No sabes en qué área encajas?</h2>
          <p class="lead">Es normal. Muchas veces los síntomas se solapan. En una primera visita lo valoramos juntas y trazamos el camino.</p>
        </div>
        <a href={site.bookingUrl} class="btn btn--on-dark">
          Pide cita
          <svg class="btn__arrow" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true"><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding-block: clamp(2.5rem, 1.8rem + 3vw, 4.5rem) var(--space-l); }
  .page-hero .lead { margin-top: var(--space-s); }
  .page-hero h1 { margin-top: var(--space-2xs); }

  .subnav {
    position: sticky; top: 4.6rem; z-index: 20;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-block: 1px solid var(--line);
  }
  .subnav__inner { display: flex; gap: 0.4rem; overflow-x: auto; scrollbar-width: none; padding-block: 0.6rem; }
  .subnav__inner::-webkit-scrollbar { display: none; }
  .subnav__link {
    display: inline-flex; align-items: center; gap: 0.5rem; white-space: nowrap;
    padding: 0.5rem 0.9rem; border-radius: var(--r-pill);
    font-weight: 500; font-size: 0.92rem; color: var(--ink-soft);
    transition: background-color .2s, color .2s;
  }
  .subnav__link:hover { background: var(--sage-pale); color: var(--forest); }
  .subnav__num { font-family: var(--serif); font-style: italic; color: var(--terracotta); font-size: 0.9rem; }

  .area-detail { padding-block: var(--space-xl); }
  .area-detail__grid { display: grid; gap: var(--space-l); align-items: center; }
  @media (min-width: 900px) { .area-detail__grid { grid-template-columns: 1fr 1fr; gap: var(--space-xl); } }
  .area-detail__media { position: relative; }
  @media (min-width: 900px) { .area-detail__media.is-right { order: 2; } }
  .area-detail__badge {
    position: absolute; top: -1rem; left: -1rem;
    display: grid; place-items: center; width: 60px; height: 60px;
    background: var(--bg); border: 1px solid var(--line); border-radius: 16px;
    box-shadow: var(--shadow-m); color: var(--forest);
  }
  .area-detail__head { display: flex; align-items: baseline; gap: 0.8rem; margin-bottom: var(--space-s); }
  .area-detail__num { font-size: 1.5rem; }
  .area-detail__list { display: grid; gap: var(--space-s); margin-top: var(--space-m); }
  .area-detail__list li { display: flex; gap: 0.85rem; align-items: flex-start; }
  .area-detail__check { flex: none; display: grid; place-items: center; width: 26px; height: 26px; margin-top: 2px; border-radius: 8px; background: var(--forest); color: var(--on-forest); }
  .area-detail__name { font-weight: 600; color: var(--ink); }
  .area-detail__desc { color: var(--muted); font-size: 0.95rem; margin-top: 1px; }

  .consulta-cta {
    border-radius: var(--r-lg); padding: clamp(2rem, 1.4rem + 3vw, 3.5rem);
    display: grid; gap: var(--space-m); align-items: center;
  }
  @media (min-width: 820px) { .consulta-cta { grid-template-columns: 1.6fr auto; gap: var(--space-l); } }
  .consulta-cta .lead { margin-top: 0.5rem; max-width: 46ch; }
</style>

<script>
  // Resalta el enlace de la sub-nav según la sección visible
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>(".subnav__link"));
  const map = new Map(links.map((l) => [l.getAttribute("href")?.slice(1), l]));
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          links.forEach((l) => l.removeAttribute("data-active"));
          map.get(e.target.id)?.setAttribute("data-active", "");
        }
      });
    },
    { rootMargin: "-30% 0px -60% 0px" }
  );
  document.querySelectorAll(".area-detail").forEach((s) => io.observe(s));
</script>

<style is:global>
  .subnav__link[data-active] { background: var(--forest); color: var(--on-forest); }
  .subnav__link[data-active] .subnav__num { color: var(--sage); }
</style>
