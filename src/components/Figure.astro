---
// Foto atmosférica (stock verificado de Unsplash). Sustituible por fotos propias.
interface Props {
  id: string;          // id de Unsplash: photo-XXXX
  alt: string;
  ratio?: string;
  class?: string;
  sizes?: string;
  eager?: boolean;
}
const { id, alt, ratio = "4 / 3", class: cls = "", sizes = "(min-width: 900px) 40vw, 100vw", eager = false } = Astro.props;
const base = `https://images.unsplash.com/${id}?auto=format&fit=crop&q=80`;
const src = `${base}&w=1200`;
const srcset = [640, 960, 1200, 1600].map((w) => `${base}&w=${w} ${w}w`).join(", ");
---
<figure class={`figure ${cls}`} style={`--ratio:${ratio}`}>
  <img
    src={src}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    loading={eager ? "eager" : "lazy"}
    decoding="async"
    fetchpriority={eager ? "high" : undefined}
  />
</figure>

<style>
  .figure { position: relative; aspect-ratio: var(--ratio); border-radius: var(--r-lg); overflow: hidden; background: var(--sage-pale); }
  .figure img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
</style>
